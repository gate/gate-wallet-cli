{
  "name": "gate-wallet-cli",
  "version": "1.0.0",
  "description": "Gate Wallet CLI - MCP Custodial Wallet Management Tool",
  "type": "module",
  "main": "dist/cli/index.js",
  "bin": {
    "gate-wallet": "./bin/gate-wallet.js"
  },
  "files": [
    "dist",
    "bin",
    "SKILL.md",
    "skills",
    ".env.defaults"
  ],
  "scripts": {
    "cli": "tsx src/cli/index.ts",
    "build": "tsc && cp ../skills/gate-wallet-cli/SKILL.md . && mkdir -p skills/gate-dex-trade && cp ../skills/gate-dex-trade/SKILL.md skills/gate-dex-trade/ && chmod +x bin/gate-wallet.js",
    "dev": "tsx --watch src/cli/index.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "gate",
    "wallet",
    "cli",
    "mcp",
    "web3"
  ],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "open": "^11.0.0",
    "ora": "^9.3.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
