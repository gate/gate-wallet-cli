{
  "name": "gate-wallet-cli",
  "version": "1.0.7",
  "description": "Gate Wallet CLI - MCP Custodial Wallet Management Tool",
  "type": "module",
  "main": "dist/cli/index.js",
  "bin": {
    "gate-wallet": "./bin/gate-wallet.js"
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "cli": "tsx src/cli/index.ts",
    "build": "tsc && chmod +x bin/gate-wallet.js",
    "dev": "tsx --watch src/cli/index.ts",
    "test:mcp": "MCP_URL=https://wallet-service-mcp-test.gateweb3.cc/mcp tsx src/test/mcp-tools.test.ts",
    "prepublishOnly": "cp ../README.md ./README.md && npm run build",
    "preuninstall": "node ./bin/uninstall.cjs"
  },
  "keywords": [
    "gate",
    "wallet",
    "cli",
    "mcp",
    "web3"
  ],
  "author": "Gate",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/gate/gate-wallet-cli.git",
    "directory": "cli"
  },
  "homepage": "https://github.com/gate/gate-wallet-cli#readme",
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "open": "^11.0.0",
    "ora": "^9.3.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
